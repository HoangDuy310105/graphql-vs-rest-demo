type Query {
    author(id: ID!): Author
}

type Author {
    id: ID!
    name: String!
    age: Int
    phone: String
    email: String
    posts: [Post]
}

type Post {
    id: ID!
    title: String!
    content: String
}

type Mutation {
    createPost(title: String!, content: String, authorId: ID!): Post
}
